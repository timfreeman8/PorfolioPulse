# SAT Portfolio Pulse — Environment Variables
#
# Copy this file to .env.local for local development.
# In Azure Static Web Apps, set these in Application Settings (not committed to source).
#
# Phase 1 (current): All persistence is localStorage — no env vars required to run.
# Phase 2 (backend): Uncomment and populate the variables below when wiring up the API.

# ── Azure AD / Entra ID (Authentication) ─────────────────────────────────────
# Required when MSAL auth is added (Phase 2).
# VITE_TENANT_ID=your-azure-tenant-id
# VITE_CLIENT_ID=your-app-registration-client-id

# ── API / Backend ─────────────────────────────────────────────────────────────
# Base URL for the Azure Functions API layer (Phase 2).
# VITE_API_BASE_URL=https://your-function-app.azurewebsites.net/api

# ── Feature Flags (optional) ─────────────────────────────────────────────────
# VITE_ENABLE_TEAMS_WEBHOOK=true
